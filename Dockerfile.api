FROM node:20-alpine

RUN npm install -g pnpm@8

WORKDIR /app

# Copier TOUT le contexte (node_modules exclus via .dockerignore)
COPY . .

# Installer les dépendances du workspace (production only)
RUN pnpm install --frozen-lockfile --prod

EXPOSE 3001

CMD ["node", "monorepo-chat/api/src/index.js"]
